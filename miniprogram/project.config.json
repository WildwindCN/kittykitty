{
  "description": "KittyKitty - 猫咪收集 AR 小程序",
  "packOptions": { "ignore": [], "include": [] },
  "setting": {
    "urlCheck": true,
    "es6": true,
    "enhance": true,
    "postcss": true,
    "preloadBackgroundData": false,
    "minified": true,
    "newFeature": true,
    "coverView": true,
    "nodeModules": false,
    "autoAudits": false,
    "showShadowRootInWxmlPanel": true,
    "scopeDataCheck": false,
    "uglifyFileName": false,
    "checkInvalidKey": true,
    "checkSiteMap": true,
    "uploadWithSourceMap": true,
    "compileHotReLoad": false,
    "babelSetting": {
      "ignore": [],
      "disablePlugins": [],
      "outputPath": ""
    },
    "useIsolateContext": true
  },
  "compileType": "miniprogram",
  "libVersion": "3.3.4",
  "appid": "YOUR_APPID",
  "projectname": "kittykitty-miniprogram",
  "condition": {},
  "cloudfunctionRoot": "../cloudfunctions/"
}
