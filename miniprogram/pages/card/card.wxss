.card-frame { background:#1C1C2E; border-radius:24rpx; padding:0; overflow:hidden; }
.border-common { border:3rpx solid #9E9E9E; }
.border-rare { border:3rpx solid #4FC3F7; }
.border-epic { border:3rpx solid #CE93D8; }
.border-legendary { border:3rpx solid #FFD700; }

.name-bar { display:flex; justify-content:space-between; align-items:center; padding:20rpx 24rpx; }
.card-name { font-size:36rpx; font-weight:bold; color:#fff; }
.rarity-badge { font-size:22rpx; padding:4rpx 16rpx; border-radius:8rpx; }

.card-image { width:100%; height:440rpx; }
.card-image.placeholder { display:flex; align-items:center; justify-content:center; font-size:120rpx; background:rgba(255,255,255,0.03); }

.cp-section { display:flex; flex-direction:column; align-items:flex-end; padding:16rpx 24rpx; }
.cp-label { font-size:22rpx; color:rgba(255,255,255,0.3); }
.cp-value { font-size:52rpx; font-weight:900; }

.stats { padding:0 24rpx 16rpx; }
.stat-row { display:flex; align-items:center; gap:12rpx; margin-bottom:8rpx; }
.stat-label { width:60rpx; font-size:22rpx; font-weight:bold; }
.stat-bar { flex:1; }
.stat-num { width:60rpx; font-size:22rpx; text-align:right; color:rgba(255,255,255,0.6); }

.skills, .life-skills { padding:16rpx 24rpx; }
.section-title { font-size:24rpx; color:rgba(255,255,255,0.3); margin-bottom:8rpx; display:block; }
.skill-item { display:flex; justify-content:space-between; padding:6rpx 0; }
.skill-name { font-size:26rpx; color:#fff; }
.skill-power { font-size:22rpx; color:rgba(255,255,255,0.4); }

.actions { padding:24rpx; }
