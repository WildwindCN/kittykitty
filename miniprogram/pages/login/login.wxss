.logo-section { display:flex; flex-direction:column; align-items:center; padding:100rpx 0 60rpx; }
.logo-emoji { font-size:120rpx; }
.app-name { font-size:52rpx; font-weight:bold; color:#E94560; margin-top:20rpx; }
.app-desc { font-size:28rpx; color:rgba(255,255,255,0.4); margin-top:16rpx; }

.form-section { padding:0 40rpx; }
.phone-row { display:flex; gap:16rpx; margin-bottom:24rpx; }
.flex-1 { flex:1; }
.sms-btn { width:200rpx; height:96rpx; line-height:96rpx; font-size:26rpx; background:#E94560; color:#fff; border-radius:16rpx; text-align:center; padding:0; }
.sms-btn.disabled { background:rgba(255,255,255,0.1); color:rgba(255,255,255,0.3); }
.code-input { margin-bottom:32rpx; }
.login-btn { width:100%; margin-bottom:16rpx; }
.error-msg { color:#FF6B6B; font-size:26rpx; text-align:center; }
.footer { text-align:center; padding:60rpx; }
.footer-text { font-size:22rpx; color:rgba(255,255,255,0.2); }
