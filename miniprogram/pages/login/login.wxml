<!-- 登录页 -->
<view class="container">
  <view class="logo-section">
    <text class="logo-emoji">🐱</text>
    <text class="app-name">KittyKitty</text>
    <text class="app-desc">发现身边的猫咪，开始收集之旅</text>
  </view>

  <view class="form-section">
    <view class="phone-row">
      <input class="input-field flex-1" type="number" maxlength="11" placeholder="请输入手机号" value="{{phone}}" bindinput="onPhoneInput"/>
      <button class="sms-btn {{countdown > 0 ? 'disabled' : ''}}" bindtap="sendSms" disabled="{{countdown > 0 || sending}}">
        {{countdown > 0 ? countdown + 's' : '获取验证码'}}
      </button>
    </view>

    <input class="input-field code-input" type="number" maxlength="6" placeholder="6位验证码" value="{{code}}" bindinput="onCodeInput"/>

    <button class="btn-primary login-btn" bindtap="doLogin" disabled="{{loading}}" loading="{{loading}}">登录</button>

    <view class="error-msg" wx:if="{{error}}">{{error}}</view>
  </view>

  <view class="footer">
    <text class="footer-text">登录即表示同意《用户协议》和《隐私政策》</text>
  </view>
</view>
