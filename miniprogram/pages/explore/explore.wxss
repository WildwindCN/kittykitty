.header { display:flex; justify-content:space-between; align-items:center; padding:20rpx 0; }
.title { font-size:36rpx; font-weight:bold; }
.refresh-btn { background:transparent; color:#E94560; font-size:26rpx; padding:0; border:none; }

.loading-box, .error-box { padding:200rpx 0; text-align:center; }
.loading-text, .error-text { font-size:28rpx; color:rgba(255,255,255,0.5); }

.cat-list { padding-top:10rpx; }
.cat-card { display:flex; align-items:center; gap:20rpx; }
.cat-avatar { width:88rpx; height:88rpx; border-radius:16rpx; }
.cat-avatar.placeholder { display:flex; align-items:center; justify-content:center; font-size:48rpx; background:rgba(255,255,255,0.05); }
.cat-info { flex:1; }
.cat-name { font-size:30rpx; font-weight:600; }
.cat-rarity { font-size:22rpx; margin-top:4rpx; }
.cat-cp { font-size:26rpx; margin-top:4rpx; }
.arrow { font-size:36rpx; color:rgba(255,255,255,0.2); }

.empty-box { text-align:center; padding:200rpx 0; }
.empty-icon { font-size:100rpx; }
.empty-text { font-size:30rpx; color:rgba(255,255,255,0.4); margin-top:20rpx; }
.empty-sub { font-size:24rpx; color:rgba(255,255,255,0.2); margin-top:10rpx; }
