<!-- 探索页 — 附近猫咪列表 -->
<view class="container">
  <view class="header">
    <text class="title">附近猫咪</text>
    <button class="refresh-btn" bindtap="loadNearby" loading="{{loading}}">
      <text wx:if="{{!loading}}">🔄 刷新</text>
    </button>
  </view>

  <!-- 加载中 -->
  <view class="loading-box" wx:if="{{loading}}">
    <text class="loading-text">正在搜索附近的猫咪...</text>
  </view>

  <!-- 错误 -->
  <view class="error-box" wx:elif="{{error}}">
    <text class="error-text">{{error}}</text>
    <button class="btn-ghost" bindtap="loadNearby">重试</button>
  </view>

  <!-- 猫咪列表 -->
  <view class="cat-list" wx:else>
    <view wx:if="{{cats.length === 0}}" class="empty-box">
      <text class="empty-icon">🐱</text>
      <text class="empty-text">附近暂无猫咪</text>
      <text class="empty-sub">出门探索发现更多猫咪吧！</text>
    </view>

    <view class="cat-card card {{'bg-rarity-' + item.rarity}}" wx:for="{{cats}}" wx:key="id" bindtap="goDetail" data-id="{{item.id || item._id}}">
      <image class="cat-avatar" src="{{item.imageUrl}}" mode="aspectFill" wx:if="{{item.imageUrl}}"/>
      <view class="cat-avatar placeholder" wx:else>🐱</view>
      <view class="cat-info">
        <text class="cat-name">{{item.name || '???'}}</text>
        <text class="cat-rarity rarity-{{item.rarity}}">{{rarityLabel(item.rarity)}}</text>
        <text class="cat-cp">CP {{item.cp}}</text>
      </view>
      <text class="arrow">›</text>
    </view>
  </view>
</view>
