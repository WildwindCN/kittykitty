.profile-header { display:flex; flex-direction:column; align-items:center; padding:60rpx 0 40rpx; }
.avatar { width:160rpx; height:160rpx; border-radius:50%; }
.avatar.placeholder { width:160rpx; height:160rpx; border-radius:50%; background:rgba(255,255,255,0.05); display:flex; align-items:center; justify-content:center; font-size:80rpx; }
.nickname { font-size:40rpx; font-weight:bold; margin-top:20rpx; }
.phone { font-size:24rpx; color:rgba(255,255,255,0.3); margin-top:8rpx; }

.stats-row { display:flex; justify-content:space-around; padding:30rpx 0; border-top:1rpx solid rgba(255,255,255,0.06); border-bottom:1rpx solid rgba(255,255,255,0.06); margin:20rpx 0; }
.stat-item { text-align:center; }
.stat-value { font-size:44rpx; font-weight:bold; color:#E94560; }
.stat-label { font-size:22rpx; color:rgba(255,255,255,0.3); margin-top:4rpx; display:block; }

.menu-list { margin-top:30rpx; }
.menu-item { display:flex; justify-content:space-between; padding:24rpx 0; border-bottom:1rpx solid rgba(255,255,255,0.06); font-size:28rpx; }
.logout-btn { width:100%; margin-top:40rpx; background:transparent; color:#FF6B6B; border:2rpx solid rgba(255,107,107,0.3); border-radius:16rpx; font-size:28rpx; }
