.battle-area { padding:20rpx 0; }
.vs-display { display:flex; align-items:center; justify-content:space-around; padding:20rpx; }
.fighter { flex:1; text-align:center; padding:16rpx; border-radius:16rpx; }
.fighter.active { background:rgba(233,69,96,0.1); border:2rpx solid rgba(233,69,96,0.3); }
.fighter-name { font-size:28rpx; font-weight:bold; }
.hp-bar { height:16rpx; border-radius:8rpx; background:rgba(255,255,255,0.1); margin:8rpx 0; overflow:hidden; }
.hp-inner { height:100%; border-radius:8rpx; transition:width 0.4s; }
.hp-text { font-size:22rpx; color:rgba(255,255,255,0.5); }
.cp-text { font-size:22rpx; margin-top:4rpx; }
.vs-text { font-size:32rpx; font-weight:bold; color:#E94560; padding:0 16rpx; }

.battle-log { margin:20rpx 0; max-height:400rpx; overflow-y:auto; }
.log-item { display:flex; gap:12rpx; padding:4rpx 0; font-size:22rpx; }
.log-round { color:rgba(255,255,255,0.2); font-family:monospace; min-width:30rpx; }

.battle-progress { padding:20rpx 0; }
.result-area { text-align:center; padding:100rpx 0; }
.result-icon { font-size:120rpx; }
.result-text { font-size:48rpx; font-weight:bold; margin:20rpx 0; }
.result-detail { font-size:26rpx; color:rgba(255,255,255,0.4); margin-bottom:40rpx; }
